{
  "name": "claude-code-trees",
  "version": "1.0.0",
  "description": "Multi-agent parallel orchestration for Claude Code instances with Docker isolation",
  "main": "src/index.js",
  "type": "module",
  "bin": {
    "claude-code-trees": "src/index.js"
  },
  "scripts": {
    "cli": "node src/index.js",
    "serve": "node src/server.js",
    "docker:build": "docker build -t claude-code-sandbox .",
    "docker:build:patch": "docker build -f Dockerfile.patch -t claude-code-sandbox .",
    "test:api": "node test/test-api.js",
    "test:callback": "node test/callback-server.js"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "marked": "^17.0.4",
    "multer": "^2.1.1",
    "unzipper": "^0.12.3"
  }
}
