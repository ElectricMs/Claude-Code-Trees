# === API Configuration ===
# Direct Anthropic access:
# ANTHROPIC_API_KEY=sk-ant-xxxxx
# BigModel (ZhipuAI) proxy — fill in your ZhipuAI key and uncomment:
ANTHROPIC_API_KEY=your_zhipu_api_key
ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
API_TIMEOUT_MS=3000000

# === Model Configuration ===
CLAUDE_MODEL=sonnet
# BigModel (ZhipuAI) 模型映射 — Claude Code 内部别名 → GLM 实际模型名
ANTHROPIC_DEFAULT_HAIKU_MODEL=glm-4.5-air
ANTHROPIC_DEFAULT_SONNET_MODEL=glm-4.7
ANTHROPIC_DEFAULT_OPUS_MODEL=glm-5

# === Runtime Parameters ===
CONCURRENCY=2
TIMEOUT_MS=300000
# Base directory for code repositories (absolute or relative to project root)
REPOS_BASE_DIR=./repos
# Results output directory
RESULTS_DIR=./results

# === Server Configuration ===
SERVER_PORT=3000
SERVER_HOST=0.0.0.0

# === Docker Configuration ===
DOCKER_IMAGE=claude-code-sandbox
# Container memory limit (optional)
# DOCKER_MEMORY_LIMIT=2g

# === Claude Code Tool Set (read-only) ===
ALLOWED_TOOLS=Read,Grep,Glob,LS
